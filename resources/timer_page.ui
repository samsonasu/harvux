<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="HarvuxTimerPage" parent="GtkBox">
    <property name="orientation">vertical</property>
    <property name="spacing">0</property>

    <!-- Timer controls section -->
    <child>
      <object class="GtkBox" id="timer_section">
        <property name="orientation">vertical</property>
        <property name="spacing">12</property>
        <property name="margin-start">16</property>
        <property name="margin-end">16</property>
        <property name="margin-top">16</property>
        <property name="margin-bottom">8</property>
        <child>
          <object class="AdwPreferencesGroup">
            <child>
              <object class="AdwComboRow" id="project_row">
                <property name="title" translatable="yes">Project</property>
                <property name="use-subtitle">true</property>
                <property name="expression">
                  <lookup type="GtkStringObject" name="string"/>
                </property>
              </object>
            </child>
            <child>
              <object class="AdwComboRow" id="task_row">
                <property name="title" translatable="yes">Task</property>
                <property name="use-subtitle">true</property>
                <property name="sensitive">false</property>
                <property name="expression">
                  <lookup type="GtkStringObject" name="string"/>
                </property>
              </object>
            </child>
            <child>
              <object class="AdwEntryRow" id="notes_row">
                <property name="title" translatable="yes">Notes</property>
              </object>
            </child>
          </object>
        </child>

        <!-- Timer display + button -->
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="spacing">8</property>
            <property name="halign">center</property>
            <child>
              <object class="GtkLabel" id="timer_label">
                <property name="label">00:00:00</property>
                <property name="css-classes">title-1</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="timer_button">
                <property name="label" translatable="yes">Start Timer</property>
                <property name="css-classes">suggested-action
pill</property>
                <property name="halign">center</property>
                <property name="sensitive">false</property>
                <signal name="clicked" handler="on_timer_clicked" swapped="true"/>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkSeparator">
        <property name="margin-top">8</property>
      </object>
    </child>

    <!-- Today's entries section -->
    <child>
      <object class="GtkBox">
        <property name="orientation">horizontal</property>
        <property name="margin-start">16</property>
        <property name="margin-end">16</property>
        <property name="margin-top">12</property>
        <property name="margin-bottom">4</property>
        <child>
          <object class="GtkLabel">
            <property name="label" translatable="yes">Today</property>
            <property name="css-classes">heading</property>
            <property name="hexpand">true</property>
            <property name="xalign">0</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="total_label">
            <property name="label">0h 00m</property>
            <property name="css-classes">heading</property>
          </object>
        </child>
      </object>
    </child>

    <child>
      <object class="GtkScrolledWindow">
        <property name="vexpand">true</property>
        <property name="hscrollbar-policy">never</property>
        <child>
          <object class="GtkListBox" id="entries_list">
            <property name="selection-mode">none</property>
            <property name="css-classes">boxed-list</property>
            <property name="margin-start">16</property>
            <property name="margin-end">16</property>
            <property name="margin-bottom">16</property>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>
